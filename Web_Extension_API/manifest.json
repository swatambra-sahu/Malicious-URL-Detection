{
  "manifest_version": 3,
  "name": "Malicious URL Predictor",
  "version": "1.0",
  "description": "Detect malicious URLs using Flask ML API",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
